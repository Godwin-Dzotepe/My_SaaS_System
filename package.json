{
  "name": "my-school-saas",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "prisma generate && next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "node ./node_modules/eslint/bin/eslint.js",
    "lint:parent": "node ./node_modules/eslint/bin/eslint.js app/dashboard/parent app/api/parent",
    "prisma:generate": "node ./node_modules/prisma/build/index.js generate",
    "db:mysql:setup": "node scripts/setup-mysql.js",
    "db:mysql:migrate": "node ./node_modules/prisma/build/index.js migrate dev --name init_mysql",
    "db:transfer:pg-to-mysql": "node scripts/migrate-postgres-to-mysql.js"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"commonjs\"} scripts/seed-data.ts"
  },
  "dependencies": {
    "@google-cloud/firestore": "^8.3.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@prisma/adapter-mariadb": "^7.5.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.18.0",
    "@types/qrcode": "^1.5.6",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "firebase-admin": "^13.8.0",
    "framer-motion": "^12.35.2",
    "html2canvas": "^1.4.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "pg": "^8.20.0",
    "prisma": "^7.5.0",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0",
    "web-push": "^3.6.7",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
