// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

// --- New Models ---

model SchoolPaymentDetail {
  id                  String   @id @default(uuid())
  school_id           String   @unique // Link to the School model
  school              School   @relation(fields: [school_id], references: [id])
  momoNumber          String? // Mobile Money number
  bankAccountNumber   String?
  bankName            String?
  paymentInstructions String? // General instructions for payment
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
}

enum PaymentMethod {
  MOMO // Mobile Money
  BANK_TRANSFER
  CARD
  CASH
}

model Payment {
  id            String        @id @default(uuid())
  student_id    String // Link to the Student model
  student       Student       @relation(fields: [student_id], references: [id])
  parent_id     String // Link to the User model (parent)
  parent        User          @relation("ParentPayments", fields: [parent_id], references: [id])
  school_id     String // Link to the School model
  school        School        @relation(fields: [school_id], references: [id])
  amount        Float
  status        PaymentStatus @default(PENDING)
  paymentMethod PaymentMethod
  referralName  String // Student's name for referral
  transactionId String? // Optional transaction ID from payment gateway/provider
  paidAt        DateTime? // Timestamp when payment was confirmed as paid
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt
}

// --- Existing Models (with minor adjustments if necessary) ---

model School {
  id          String   @id @default(uuid())
  school_name String
  address     String
  phone       String
  created_at  DateTime @default(now())

  users               User[]
  classes             Class[]
  students            Student[]
  subjects            Subject[]
  announcements       Announcement[]
  events              Event[]
  schoolPaymentDetail SchoolPaymentDetail?
  gradingConfigs      GradingConfig[]
  schoolFees          SchoolFee[]
  payments            Payment[]
}

enum Role {
  super_admin
  school_admin
  finance_admin
  secretary
  teacher
  parent // Already exists
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String?
  start_date  DateTime
  end_date    DateTime
  school_id   String
  school      School   @relation(fields: [school_id], references: [id])
  created_by  String
  creator     User     @relation("EventCreator", fields: [created_by], references: [id])
  created_at  DateTime @default(now())
}

model User {
  id        String  @id @default(uuid())
  name      String
  phone     String  @unique
  email     String? @unique
  password  String
  role      Role
  school_id String?
  school    School? @relation(fields: [school_id], references: [id])

  // Relations for specific roles
  classes        Class[] // A teacher can manage multiple classes (or one)
  announcements  Announcement[] // Created by school admin
  homework       Homework[]
  created_events Event[]        @relation("EventCreator")
  payments       Payment[]      @relation("ParentPayments")

  subjects Subject[] @relation("TeacherSubjects")

  created_at DateTime @default(now())
}

model Class {
  id         String  @id @default(uuid())
  class_name String
  school_id  String
  school     School  @relation(fields: [school_id], references: [id])
  teacher_id String?
  teacher    User?   @relation(fields: [teacher_id], references: [id])

  students Student[]
  homework Homework[]
}

enum StudentStatus {
  active
  completed
}

model Student {
  id             String  @id @default(uuid())
  student_number String? // Unique per school, not globally
  name           String
  class_id       String
  class          Class   @relation(fields: [class_id], references: [id])
  school_id      String
  school         School  @relation(fields: [school_id], references: [id])
  parent_phone   String // Link to parent via phone (keeping as it was)
  parent_name    String?
  parent_relation String? @default("Guardian")

  status     StudentStatus @default(active)
  created_at DateTime      @default(now())

  scores            Score[]
  attendance        Attendance[]
  payments          Payment[]
  completed_records CompletedStudent?

  @@unique([school_id, student_number])
}

model Subject {
  id           String @id @default(uuid())
  subject_name String
  school_id    String
  school       School @relation(fields: [school_id], references: [id])

  scores   Score[]
  teachers User[]  @relation("TeacherSubjects")
}

model Score {
  id            String   @id @default(uuid())
  student_id    String
  student       Student  @relation(fields: [student_id], references: [id])
  subject_id    String
  subject       Subject  @relation(fields: [subject_id], references: [id])
  score         Float
  term          String
  academic_year String
  created_at    DateTime @default(now())
}

enum AttendanceStatus {
  present
  absent
}

model Attendance {
  id         String           @id @default(uuid())
  student_id String
  student    Student          @relation(fields: [student_id], references: [id])
  date       DateTime         @default(now())
  status     AttendanceStatus
}

