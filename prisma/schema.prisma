model Announcement {
  id         String   @id @default(uuid())
  school_id  String?
  school     School?  @relation(fields: [school_id], references: [id])
  message    String
  created_by String
  creator    User     @relation(fields: [created_by], references: [id])
  created_at DateTime @default(now())
}

model CompletedStudent {
  id              String   @id @default(uuid())
  student_id      String   @unique
  student         Student  @relation(fields: [student_id], references: [id])
  graduation_year Int
  created_at      DateTime @default(now())
}

model Homework {
  id          String    @id @default(uuid())
  title       String
  description String?
  file_url    String?
  class_id    String
  class       Class     @relation(fields: [class_id], references: [id])
  teacher_id  String
  teacher     User      @relation(fields: [teacher_id], references: [id])
  due_date    DateTime?
  created_at  DateTime  @default(now())
}

// Grading System Configuration
model GradingConfig {
  id         String   @id @default(uuid())
  school_id  String
  school     School   @relation(fields: [school_id], references: [id])
  grade      String // Letter grade: A, B, C, D, F
  min_score  Int // Minimum score for this grade
  max_score  Int // Maximum score for this grade
  remark     String // e.g., "Excellent", "Very Good", "Pass", "Fail"
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([school_id, grade])
}

enum PromotionAction {
  PROMOTED
  REPEATED
  GRADUATED
}

model StudentPromotionHistory {
  id              String          @id @default(uuid())
  school_id       String
  school          School          @relation(fields: [school_id], references: [id])
  student_id      String
  student         Student         @relation(fields: [student_id], references: [id])
  from_class_id   String
  fromClass       Class           @relation("PromotionFromClass", fields: [from_class_id], references: [id])
  to_class_id     String?
  toClass         Class?          @relation("PromotionToClass", fields: [to_class_id], references: [id])
  action          PromotionAction
  note            String?
  performed_by    String
  performedBy     User            @relation("PromotionPerformedBy", fields: [performed_by], references: [id])
  created_at      DateTime        @default(now())

  @@index([school_id, created_at])
  @@index([student_id, created_at])
  @@index([from_class_id, to_class_id])
}

model AcademicPeriod {
  id            String   @id @default(uuid())
  school_id     String
  school        School   @relation(fields: [school_id], references: [id])
  academic_year String
  term          String
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@unique([school_id, academic_year, term])
  @@index([school_id, academic_year, term])
}

// School Fees Configuration
model SchoolFee {
  id            String    @id @default(uuid())
  school_id     String
  school        School    @relation(fields: [school_id], references: [id])
  class_id      String?
  class         Class?    @relation(fields: [class_id], references: [id])
  fee_type      String
  amount        Float
  academic_year String // e.g., "2024-2025"
  term          String? // e.g., "Term 1", "Term 2", "Term 3"
  description   String?
  due_date      DateTime?
  is_active     Boolean   @default(true)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  studentFeeBalances StudentFeeBalance[]
}

// Note: StudentFee model removed - using Payment model instead for tracking student fees

// Added relation for User to Payment model
// This is a many-to-many relation from User to Payment through the 'ParentPayments' relation name.
// It signifies that a User (acting as a parent) can have multiple payments.
// The `Payment` model has `parentId` which establishes the link.
// This explicit relation name makes it clear the User is acting as a parent for these payments.
// This line ensures the Prisma client knows about this specific relationship.
// No change needed in the User model itself, just added a comment about its existence.
// 'ParentPayments[]' is declared in the User model.

model TeacherAttendance {
  id         String           @id @default(uuid())
  teacher_id String
  teacher    User             @relation("TeacherAttendance", fields: [teacher_id], references: [id])
  school_id  String
  school     School           @relation(fields: [school_id], references: [id])
  date       DateTime         @default(now())
  status     AttendanceStatus
  created_at DateTime         @default(now())
  updated_at DateTime         @default(now()) @updatedAt

  @@unique([teacher_id, date])
}

model StudentFeeBalance {
  id            String    @id @default(uuid())
  school_id     String
  school        School    @relation(fields: [school_id], references: [id])
  student_id    String
  student       Student   @relation(fields: [student_id], references: [id])
  school_fee_id String
  schoolFee     SchoolFee @relation(fields: [school_fee_id], references: [id])
  amount_paid   Float     @default(0)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  @@unique([student_id, school_fee_id])
  @@index([school_id, student_id])
  @@index([school_fee_id])
}

enum MessageAudience {
  school_admin
  teacher
  parent
  secretary
  finance_admin
}

model AppMessage {
  id               String          @id @default(uuid())
  school_id        String?
  school           School?         @relation(fields: [school_id], references: [id])
  sender_id        String
  sender           User            @relation("MessageSender", fields: [sender_id], references: [id])
  recipient_id     String
  recipient        User            @relation("MessageRecipient", fields: [recipient_id], references: [id])
  sender_role      Role
  recipient_role   Role
  title            String
  body             String
  school_name      String?
  notifications    AppNotification[]
  is_edited        Boolean         @default(false)
  edited_at        DateTime?
  created_at       DateTime        @default(now())
  updated_at       DateTime        @updatedAt
}

model AppNotification {
  id               String          @id @default(uuid())
  user_id          String
  user             User            @relation(fields: [user_id], references: [id])
  school_id        String?
  school           School?         @relation(fields: [school_id], references: [id])
  message_id       String?
  message          AppMessage?     @relation(fields: [message_id], references: [id])
  title            String
  body             String
  source_role      Role?
  source_name      String?
  school_name      String?
  is_read          Boolean         @default(false)
  created_at       DateTime        @default(now())
  updated_at       DateTime        @updatedAt

  @@index([user_id, is_read, created_at])
}

// JWT revocation — tokens are hashed and stored here on logout
model TokenBlacklist {
  id         String   @id @default(uuid())
  token_hash String   @unique
  expires_at DateTime
  created_at DateTime @default(now())

  @@index([expires_at])
}

// TOTP 2FA secrets for school_admin / finance_admin
model UserTotpSecret {
  id         String   @id @default(uuid())
  user_id    String   @unique
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  secret     String   // AES-256-GCM encrypted base32 secret
  verified   Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

// General-purpose audit log
model AuditLog {
  id           String   @id @default(uuid())
  school_id    String?
  performed_by String   // User ID or "system"
  actor_role   String?
  action       String   // CREATE | UPDATE | DELETE
  entity_type  String   // Student | User | SchoolFee | etc.
  entity_id    String
  changes      Json?    // { before: {...}, after: {...} }
  ip_address   String?
  created_at   DateTime @default(now())

  @@index([school_id, entity_type, created_at])
  @@index([entity_id, entity_type])
  @@index([performed_by, created_at])
}


