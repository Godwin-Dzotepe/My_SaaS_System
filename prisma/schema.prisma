// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "mysql"
}

// --- New Models ---

model SchoolPaymentDetail {
  id                  String   @id @default(uuid())
  school_id           String   @unique // Link to the School model
  school              School   @relation(fields: [school_id], references: [id])
  momoNumber          String? // Mobile Money number
  bankAccountNumber   String?
  bankName            String?
  paymentInstructions String? // General instructions for payment
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
}

enum PaymentMethod {
  MOMO // Mobile Money
  BANK_TRANSFER
  CARD
  CASH
}

model Payment {
  id            String        @id @default(uuid())
  student_id    String // Link to the Student model
  student       Student       @relation(fields: [student_id], references: [id])
  parent_id     String // Link to the User model (parent)
  parent        User          @relation("ParentPayments", fields: [parent_id], references: [id])
  school_id     String // Link to the School model
  school        School        @relation(fields: [school_id], references: [id])
  amount        Float
  status        PaymentStatus @default(PENDING)
  paymentMethod PaymentMethod
  referralName  String // Student's name for referral
  transactionId String? // Optional transaction ID from payment gateway/provider
  paidAt        DateTime? // Timestamp when payment was confirmed as paid
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt
}

// --- Existing Models (with minor adjustments if necessary) ---

model TimetableEntry {
  id            String   @id @default(uuid())
  school_id     String
  school        School   @relation(fields: [school_id], references: [id])
  class_id      String
  class         Class    @relation(fields: [class_id], references: [id])
  subject_id    String
  subject       Subject  @relation(fields: [subject_id], references: [id])
  teacher_id    String?
  teacher       User?    @relation("TimetableTeacher", fields: [teacher_id], references: [id])
  day_of_week   Int      // 1=Mon 2=Tue 3=Wed 4=Thu 5=Fri
  period_number Int
  start_time    String   // "HH:MM"
  end_time      String   // "HH:MM"
  room          String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@unique([class_id, day_of_week, period_number])
  @@index([school_id])
  @@index([teacher_id])
}

model School {
  id          String   @id @default(uuid())
  school_name String
  address     String
  logo_url    String?
  sms_username String?
  isActive    Boolean  @default(true)
  deactivationMessage String?

  phone       String
  created_at  DateTime @default(now())

  users               User[]
  classes             Class[]
  students            Student[]
  subjects            Subject[]
  announcements       Announcement[]
  messages            AppMessage[]
  notifications       AppNotification[]
  events              Event[]
  schoolPaymentDetail SchoolPaymentDetail?
  gradingConfigs      GradingConfig[]
  academicPeriods     AcademicPeriod[]
  schoolFees          SchoolFee[]
  studentFeeBalances  StudentFeeBalance[]
  payments            Payment[]
  teacherAttendance   TeacherAttendance[]
  promotionHistory    StudentPromotionHistory[]
  timetableEntries    TimetableEntry[]
}

enum Role {
  super_admin
  school_admin
  finance_admin
  secretary
  teacher
  parent // Already exists
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String?
  start_date  DateTime
  end_date    DateTime
  school_id   String
  school      School   @relation(fields: [school_id], references: [id])
  created_by  String
  creator     User     @relation("EventCreator", fields: [created_by], references: [id])
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now()) @updatedAt
}

model User {
  id        String  @id @default(uuid())
  name      String
  phone     String  @unique
  email     String? @unique
  emailVerified DateTime?
  image     String?
  password  String
  temporary_password String?
  password_generated_at DateTime?
  role      Role
  school_id String?
  school    School? @relation(fields: [school_id], references: [id])

  // OTP fields for SMS login - SECURED with hashing and rate limiting
  otp               String?  // Hashed OTP (never plain text)
  otpExpiresAt      DateTime? // Expiry time for OTP (10 minutes)
  otpAttempts       Int      @default(0) // Track failed attempts (max 5)
  lastOtpSentAt     DateTime? // Rate limiting - track last OTP request

  // Soft delete
  deleted_at DateTime?

  // Indexes for performance
  @@index([phone, role])
  @@index([school_id, phone])
  @@index([deleted_at])

  // Relations for specific roles
  classes        Class[] // A teacher can manage multiple classes (or one)
  announcements  Announcement[] // Created by school admin
  sentMessages   AppMessage[]   @relation("MessageSender")
  receivedMessages AppMessage[] @relation("MessageRecipient")
  notifications  AppNotification[]
  homework       Homework[]
  created_events Event[]        @relation("EventCreator")
  payments       Payment[]      @relation("ParentPayments")
  students       Student[]      @relation("StudentParents") // Parent's children

  subjects Subject[] @relation("TeacherSubjects")
  teacherAttendance TeacherAttendance[] @relation("TeacherAttendance")
  performedPromotions StudentPromotionHistory[] @relation("PromotionPerformedBy")
  timetableEntries TimetableEntry[] @relation("TimetableTeacher")
  totpSecret     UserTotpSecret?

  created_at DateTime @default(now())
}

model Class {
  id         String  @id @default(uuid())
  class_name String
  school_id  String
  school     School  @relation(fields: [school_id], references: [id])
  teacher_id String?
  teacher    User?   @relation(fields: [teacher_id], references: [id])

  students Student[]
  homework Homework[]
  attendance Attendance[]
  schoolFees SchoolFee[]
  promotionsFrom StudentPromotionHistory[] @relation("PromotionFromClass")
  promotionsTo   StudentPromotionHistory[] @relation("PromotionToClass")
  timetableEntries TimetableEntry[]
}

enum StudentStatus {
  active
  completed
}

model Student {
  id             String  @id @default(uuid())
  student_number String? // Unique per school, not globally
  name           String
  date_of_birth  DateTime?
  gender         String?
  nationality    String?
  admission_date DateTime?
  previous_school String?
  residential_address String?
  digital_address String?
  father_name     String?
  father_phone    String?
  father_profession String?
  father_status   String?
  father_residential_address String?
  father_digital_address String?
  mother_name     String?
  mother_phone    String?
  mother_profession String?
  mother_status   String?
  mother_residential_address String?
  mother_digital_address String?
  guardian_name   String?
  guardian_phone  String?
  guardian_profession String?
  guardian_residential_address String?
  guardian_digital_address String?
  emergency_contact_name String?
  emergency_contact_phone String?
  medical_notes  String?
  profile_image  String?
  class_id       String
  class          Class   @relation(fields: [class_id], references: [id])
  school_id      String
  school         School  @relation(fields: [school_id], references: [id])
  parent_id      String? // Link to parent User account
  parent         User?   @relation("StudentParents", fields: [parent_id], references: [id])
  parent_phone   String? // Contact phone (optional)
  parent_name    String?
  parent_relation String? @default("Guardian")

  status     StudentStatus @default(active)
  deleted_at DateTime?
  created_at DateTime      @default(now())

  scores            Score[]
  attendance        Attendance[]
  feeBalances       StudentFeeBalance[]
  payments          Payment[]
  completed_records CompletedStudent?
  promotionHistory  StudentPromotionHistory[]

  @@unique([school_id, student_number])
  @@index([school_id, deleted_at])
}

model Subject {
  id           String @id @default(uuid())
  subject_name String
  school_id    String
  school       School @relation(fields: [school_id], references: [id])

  scores   Score[]
  teachers User[]  @relation("TeacherSubjects")
  timetableEntries TimetableEntry[]
}

model Score {
  id            String   @id @default(uuid())
  student_id    String
  student       Student  @relation(fields: [student_id], references: [id])
  subject_id    String
  subject       Subject  @relation(fields: [subject_id], references: [id])
  classScore    Float?
  examScore     Float?
  totalScore    Float?
  behavior      String?
  teacherAdvice String?
  grade         String?
  remark        String?
  term          String
  academic_year String
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@index([student_id, subject_id, academic_year, term])
}

enum AttendanceStatus {
  present
  absent
}

model Attendance {
  id         String           @id @default(uuid())
  student_id String
  student    Student          @relation(fields: [student_id], references: [id])
  class_id   String
  class      Class            @relation(fields: [class_id], references: [id])
  date       DateTime         @default(now())
  status     AttendanceStatus

  @@unique([student_id, date, class_id])
}

